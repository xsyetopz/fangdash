# ── Required secrets (set these in .dev.vars) ─────────────
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-32-chars
BETTER_AUTH_URL=http://localhost:8787
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here
# NOTE: You must add http://localhost:8787/api/auth/callback/twitch
# as an OAuth Redirect URL in your Twitch Developer Console app settings
# (https://dev.twitch.tv/console/apps) for local login to work.

# ── Auto-configured via wrangler.toml [vars] ──────────────
# ENVIRONMENT  → "development" (local) / "production"
# WEB_URL      → "http://localhost:3000" (local) / your web domain (prod)
# These do NOT need to be set here.

# ── Admin promotion ───────────────────────────────────────
# Use the CLI script instead of env vars:
#   bun run promote-admin YourTwitchUsername
#   bun run promote-admin YourTwitchUsername --remote   (production)
#   bun run promote-admin YourTwitchUsername --role dev  (set dev role)
