{
	"name": "fangdash",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "turbo typecheck",
		"test": "turbo test",
		"test:coverage": "turbo test -- --coverage",
		"clean": "turbo clean",
		"ship": "bun run ship:api && bun run ship:web && bun run ship:party",
		"ship:api": "bun run --filter @fangdash/api deploy",
		"ship:web": "bun run --filter @fangdash/web deploy",
		"ship:party": "bun run --filter @fangdash/party deploy",
		"promote-admin": "bun run --filter @fangdash/api promote-admin",
		"reconcile-stats": "bun run --filter @fangdash/api reconcile-stats"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@next/eslint-plugin-next": "^16.2.2",
		"@vitest/coverage-v8": "^4.1.2",
		"bun-types": "^1.3.11",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-unused-imports": "^4.4.1",
		"prettier": "^3.8.1",
		"turbo": "^2.9.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	},
	"packageManager": "bun@1.3.10",
	"engines": {
		"node": ">=20"
	}
}
