{
  "name": "fangdash",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "biome check .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "lint": "turbo lint",
    "lint:biome": "biome lint .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test -- --coverage",
    "clean": "turbo clean",
    "ship": "bun run ship:api && bun run ship:web && bun run ship:party",
    "ship:api": "bun run --filter @fangdash/api deploy",
    "ship:web": "bun run --filter @fangdash/web deploy",
    "ship:party": "bun run --filter @fangdash/party deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@vitest/coverage-v8": "^4.0.18",
    "bun-types": "^1.3.10",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=24"
  }
}
